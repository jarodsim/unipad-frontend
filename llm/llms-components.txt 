## 子组件

```tsx
import {Typography} from "@heroui/react";

export const Primitives = () => {
  return (
    <div className="flex max-w-xl flex-col gap-4">
      <Typography.Heading level={1}>仪表盘</Typography.Heading>
      <Typography.Paragraph>
